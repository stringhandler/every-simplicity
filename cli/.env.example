SIMPLICITY_HL_REPO=https://github.com/BlockstreamResearch/SimplicityHL
SIMPLICITY_HL_BRANCH=master
SIMC_FLAGS=

# Optional: set to an absolute path to build simc from local source instead of GitHub.
# Requires --rebuild-docker after any source changes.
# SIMPLICITY_HL_LOCAL_PATH=/path/to/SimplicityHL

# Optional: set to a pre-built Linux simc binary. Skips all Rust compilation — fastest option.
# Build it once with: docker run --rm -v /path/to/SimplicityHL:/src -v /tmp/out:/out \
#   rust:latest bash -c "cargo build --release --manifest-path /src/Cargo.toml && cp /src/target/release/simc /out/simc"
# SIMPLICITY_HL_BINARY_PATH=/tmp/out/simc
